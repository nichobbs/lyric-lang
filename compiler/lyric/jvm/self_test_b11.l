// jvm/self_test_b11.l — Stage B11 smoke test: ZIP/JAR assembler.
//
// Builds a minimal JAR in memory containing:
//   META-INF/MANIFEST.MF  (generated by Jvm.Manifest)
//   Hello.class            (generated by Jvm.Classfile + Jvm.Bytecode)
//
// Writes the JAR to /tmp/lyric-jvm-b11/hello.jar, then verifies:
//   - jar_written=true   (writeBytes succeeded)
//   - zip_magic_ok=true  (first 4 bytes = 0x50 0x4B 0x03 0x04)
//
// The Expecto test (JvmLoweringB11Test.fs) also runs
//   unzip -l /tmp/lyric-jvm-b11/hello.jar
// and verifies both entries appear in the output.

package Jvm.SelfTestB11

import Std.Core
import Std.Collections
import Std.File
import Jvm.Classfile
import Jvm.Bytecode
import Jvm.Manifest
import Jvm.Zip

func makeHelloClassBytes(): List[Byte] {
  val pool = poolNew()
  val asm  = newAssembler(pool)

  val outRef   = poolFieldref(pool, "java/lang/System", "out", "Ljava/io/PrintStream;")
  emitGetstatic(asm, outRef)
  emitPushString(asm, "hello from b11")
  val printRef = poolMethodref(pool, "java/io/PrintStream", "println", "(Ljava/lang/String;)V")
  emitInvokevirtual(asm, printRef)
  emitReturn(asm)

  val codeAttr = assembleCode(asm, 2, 1)
  val mainAttrs: List[Attribute] = newList()
  mainAttrs.add(codeAttr)
  val mainMethod = makeMethodInfo(ACC_PUBLIC + ACC_STATIC, "main", "([Ljava/lang/String;)V", mainAttrs)
  val cfMethods: List[MethodInfo] = newList()
  cfMethods.add(mainMethod)
  val cf = makeClassWithMethods("Hello", cfMethods)
  serializeClassWithPool(cf, pool)
}

func main(): Unit {
  val outDir = "/tmp/lyric-jvm-b11"
  match createDir(outDir) {
    case Ok(_)  -> ()
    case Err(_) -> ()
  }

  val classBytes = makeHelloClassBytes()

  val meta = PackageMeta(
    packageName = "Jvm.SelfTestB11",
    mainClass   = "Hello",
    version     = "0.1.0"
  )
  val mfBytes = stringToUtf8Bytes(makeManifestMf(meta))

  val mfEntry  = ZipEntry(name = "META-INF/MANIFEST.MF", data = mfBytes)
  val clsEntry = ZipEntry(name = "Hello.class", data = classBytes)

  val entries: List[ZipEntry] = newList()
  entries.add(mfEntry)
  entries.add(clsEntry)

  val jarBytes = buildJar(entries)

  val jarPath = outDir + "/hello.jar"
  match writeBytes(jarPath, jarBytes) {
    case Ok(_)  -> println("jar_written=true")
    case Err(_) -> println("jar_written=false")
  }

  // Verify ZIP magic: first 4 bytes must be PK\x03\x04 = 0x50 0x4B 0x03 0x04.
  if jarBytes.count >= 4 {
    if jarBytes[0] == 0x50 and jarBytes[1] == 0x4B and jarBytes[2] == 0x03 and jarBytes[3] == 0x04 {
      println("zip_magic_ok=true")
    } else {
      println("zip_magic_ok=false")
    }
  } else {
    println("zip_magic_ok=false")
  }

  println("jar_size=" + toString(jarBytes.count))
}
