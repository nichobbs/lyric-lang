<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>lyric</AssemblyName>
    <RootNamespace>Lyric.Cli.Aot</RootNamespace>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <!-- Stage-1 DLL references.  The wildcard pulls in every artefact
       `bootstrap.sh -stage 1` deposits, which is exactly the closed
       set the AOT linker needs: Lyric.Lyric.Cli.dll + transitive
       Lyric.Lyric.Pkg.dll + Lyric.Stdlib.Pkg.dll. -->
  <ItemGroup>
    <Reference Include="../../../.bootstrap/stage1/Lyric.*.dll">
      <Private>true</Private>
    </Reference>
    <!-- The self-hosted JVM backend's kernel (Jvm.Kernel) routes byte-writer
         and constant-pool operations through the F# `Lyric.Jvm.Hosts` shim,
         which depends on FSharp.Core.  The in-process JVM build path
         (emitter.l into Jvm.Bridge) therefore needs FSharp.Core deployed beside
         the AOT binary, unlike the pure-Lyric MSIL kernel.  Staged into
         .bootstrap/stage1 by bootstrap.sh. -->
    <Reference Include="../../../.bootstrap/stage1/FSharp.Core.dll">
      <Private>true</Private>
    </Reference>
  </ItemGroup>

</Project>
