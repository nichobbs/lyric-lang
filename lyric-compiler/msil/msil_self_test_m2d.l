// msil_self_test_m2d.l — Stage M2d self-test for the parameterized PE assembler.
//
// Builds a Hello-World equivalent PE using Msil.Assembler (with data identical
// to the hardcoded Msil.Pe stage-M1 image) and verifies structural layout
// invariants in the generated bytes.
//
// Checks emitted (one per line, key=value):
//   size_ok          — total image size = 1024 bytes
//   dos_ok           — DOS MZ magic at offset 0
//   pe_sig_ok        — PE\0\0 signature at offset 0x80
//   clr_cb_ok        — CLR header cb=72 at offset 0x200
//   md_rva_ok        — MetaData.VirtualAddress = 0x2054 at offset 0x208
//   md_size_ok       — MetaData.Size = 408 at offset 0x20C
//   entry_tok_ok     — EntryPointToken = 0x06000001 at offset 0x214
//   method_hdr_ok    — tiny method header 0x2E at offset 0x248
//   method_ldstr_ok  — ldstr opcode + US[1] token at offset 0x249
//   bsjb_ok          — BSJB magic at offset 0x254
//   nstreams_ok      — NumberOfStreams = 5 at offset 0x272

package Msil.SelfTestM2d

import Msil.Assembler
import Msil.Opcodes
import Msil.Tables
import Msil.Heaps
import Msil.Kernel
import Std.Core
import Std.Collections

func check(label: in String, ok: in Bool): Unit {
  if ok { println(label + "=true") } else { println(label + "=false") }
}

func main(): Unit {
  // ── Build #Strings heap ───────────────────────────────────────────────────
  // Entries added in the same order as Msil.Pe's writeStringsHeap so offsets
  // are byte-for-byte identical: "<Module>"=1, "Hello"=0x0A, "Main"=0x10,
  // "System"=0x15, "Console"=0x1C, "System.Runtime"=0x24, "Object"=0x33,
  // "WriteLine"=0x3A.

  val sh = newStringHeap()
  val sModule    = internString(sh, "<Module>")       // 1
  val sHello     = internString(sh, "Hello")           // 0x0A
  val sMain      = internString(sh, "Main")            // 0x10
  val sSystem    = internString(sh, "System")          // 0x15
  val sConsole   = internString(sh, "Console")         // 0x1C
  val sRuntime   = internString(sh, "System.Runtime")  // 0x24
  val sObject    = internString(sh, "Object")          // 0x33
  val sWriteLine = internString(sh, "WriteLine")       // 0x3A

  // ── Build #GUID heap ──────────────────────────────────────────────────────
  val gh    = newGuidHeap()
  val guidW = bufNew()
  var gi = 0
  while gi < 16 { bufU1(guidW, 0); gi = gi + 1 }
  val mvid = appendGuid(gh, bufToList(guidW))  // GUID[1] = all-zero Mvid

  // ── Build #US heap ────────────────────────────────────────────────────────
  val uh      = newUsHeap()
  val usIdx   = internUs(uh, "Hello, World!\n")  // US[1]

  // ── Build #Blob heap ──────────────────────────────────────────────────────
  val bh = newBlobHeap()

  // Main() signature: calling-convention=0x00, 0 params, void  →  {0x00,0x00,0x01}
  val mainSigW = bufNew()
  bufU1(mainSigW, 0x00)  bufU1(mainSigW, 0x00)  bufU1(mainSigW, 0x01)
  val sigMain = internBlob(bh, "main_sig", bufToList(mainSigW))      // 1

  // Console.WriteLine(string) signature: {0x00,0x01,0x01,0x0E}
  val wlSigW = bufNew()
  bufU1(wlSigW, 0x00)  bufU1(wlSigW, 0x01)  bufU1(wlSigW, 0x01)  bufU1(wlSigW, 0x0E)
  val sigWriteLine = internBlob(bh, "wl_sig", bufToList(wlSigW))     // 5

  // System.Runtime public key token: b03f5f7f11d50a3a
  val keyW = bufNew()
  bufU1(keyW, 0xB0)  bufU1(keyW, 0x3F)  bufU1(keyW, 0x5F)  bufU1(keyW, 0x7F)
  bufU1(keyW, 0x11)  bufU1(keyW, 0xD5)  bufU1(keyW, 0x0A)  bufU1(keyW, 0x3A)
  val keyToken = internBlob(bh, "sysruntime_key", bufToList(keyW))   // 0x0A

  // ── Build MetadataTables ──────────────────────────────────────────────────
  val t = newMetadataTables()

  addModule(t, ModuleRow(
    generation = 0, name = sModule, mvid = mvid, encId = 0, encBaseId = 0))

  addTypeRef(t, TypeRefRow(
    resolutionScope = rsAssemblyRef(1), typeName = sConsole, typeNamespace = sSystem))
  addTypeRef(t, TypeRefRow(
    resolutionScope = rsAssemblyRef(1), typeName = sObject,  typeNamespace = sSystem))

  addTypeDef(t, TypeDefRow(
    flags = 0, typeName = sModule, typeNamespace = 0,
    extends = 0, fieldList = 1, methodList = 1))
  addTypeDef(t, TypeDefRow(
    flags = TDF_PUBLIC, typeName = sHello, typeNamespace = 0,
    extends = tdrTypeRef(2), fieldList = 1, methodList = 1))

  addMethodDef(t, MethodDefRow(
    rva       = FIRST_METHOD_RVA,
    implFlags = 0,
    flags     = MDA_PUBLIC + MDA_STATIC + MDA_HIDE_BY_SIG,
    name      = sMain,
    signature = sigMain,
    paramList = 1))

  addMemberRef(t, MemberRefRow(
    class = mrpTypeRef(1), name = sWriteLine, signature = sigWriteLine))

  addAssembly(t, AssemblyRow(
    hashAlgId      = HASH_ALG_SHA1,
    majorVersion   = 0,
    minorVersion   = 0,
    buildNumber    = 0,
    revisionNumber = 0,
    flags          = ASF_NONE,
    publicKey      = 0,
    name           = sHello,
    culture        = 0))

  addAssemblyRef(t, AssemblyRefRow(
    majorVersion   = 10,
    minorVersion   = 0,
    buildNumber    = 0,
    revisionNumber = 0,
    flags          = 0,
    publicKeyToken = keyToken,
    name           = sRuntime,
    culture        = 0,
    hashValue      = 0))

  // ── Build method body ─────────────────────────────────────────────────────
  // Same CIL as Msil.Pe's writeMethodBody:
  //   ldstr  #US[1]       "Hello, World!\n"    token = 0x70000001
  //   call   MemberRef[1] Console.WriteLine    token = 0x0A000001
  //   ret

  val mb = newMethodBody()
  emitLdstr(mb, 0x70000001)
  emitCall(mb, 0x0A000001)
  emitRet(mb)

  // ── Assemble PE ───────────────────────────────────────────────────────────
  val bodies: List[MethodBody] = newList()
  bodies.add(mb)
  val inp = AssemblerInput(
    entryPointToken = 0x06000001,
    methodBodies    = bodies,
    tables          = t,
    strings         = sh,
    us              = uh,
    blobs           = bh,
    guids           = gh, resourceData = newList())

  val peBuf = assemblePe(inp)
  val bs = bufToList(peBuf)

  // ── Structural checks ─────────────────────────────────────────────────────

  // Total image: 512 header bytes + 512 text section raw bytes = 1024
  check("size_ok", bs.count == 1024)

  // DOS MZ magic at offset 0
  check("dos_ok", bs[0] == 0x4D and bs[1] == 0x5A)

  // PE\0\0 signature at file offset 0x80 (e_lfanew)
  check("pe_sig_ok",
    bs[0x80] == 0x50 and bs[0x81] == 0x45 and bs[0x82] == 0 and bs[0x83] == 0)

  // CLR header: cb=72 at offset 0x200
  check("clr_cb_ok",
    bs[0x200] == 72 and bs[0x201] == 0 and bs[0x202] == 0 and bs[0x203] == 0)

  // MetaData.VirtualAddress at offset 0x208 = 0x2054 (0x2000 + 72 + 12)
  check("md_rva_ok",
    bs[0x208] == 0x54 and bs[0x209] == 0x20 and bs[0x20A] == 0 and bs[0x20B] == 0)

  // MetaData.Size at offset 0x20C = 408 = 0x00000198
  check("md_size_ok",
    bs[0x20C] == 0x98 and bs[0x20D] == 0x01 and bs[0x20E] == 0 and bs[0x20F] == 0)

  // EntryPointToken at offset 0x214 = 0x06000001
  check("entry_tok_ok",
    bs[0x214] == 0x01 and bs[0x215] == 0 and bs[0x216] == 0 and bs[0x217] == 0x06)

  // Method tiny header at offset 0x248: (11 << 2) | 2 = 0x2E
  check("method_hdr_ok", bs[0x248] == 0x2E)

  // ldstr opcode (0x72) + US[1] token (0x70000001 LE) at offset 0x249
  check("method_ldstr_ok",
    bs[0x249] == 0x72 and
    bs[0x24A] == 0x01 and bs[0x24B] == 0 and bs[0x24C] == 0 and bs[0x24D] == 0x70)

  // BSJB magic at metadata root offset 0x254
  check("bsjb_ok",
    bs[0x254] == 0x42 and bs[0x255] == 0x53 and
    bs[0x256] == 0x4A and bs[0x257] == 0x42)

  // NumberOfStreams at offset 0x272 = 5
  check("nstreams_ok", bs[0x272] == 5 and bs[0x273] == 0)
}
